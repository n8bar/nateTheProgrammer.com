# Dedicated host IP the container publishes on (port 80 -> container 3000)
NTP_BIND_IP=192.168.68.xx

# Contact form destination (server-only)
CONTACT_EMAIL=you@example.com

# Contact form delivery via Resend (optional; without it, submissions are logged server-side)
RESEND_API_KEY=re_your_key_here
CONTACT_FROM=Your Name <noreply@yourdomain.com>
